# --- EDITORS & IDEs ---
# NOT: .vscode/ satırı kaldırıldı, artık VS Code ayarların Git tarafından görülebilir.
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- SYSTEM FILES ---
.DS_Store
Thumbs.db
desktop.ini

# --- LOGS & TEMPORARY ---
*.log
logs/
*.tmp
*.bak
.cache/

# --- NODE.JS / WEB ---
node_modules/
bower_components/
dist/
.next/
.nuxt/
.out/

# --- PYTHON ---
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
develop-eggs/
downloads/
eggs/
.eggs/

# --- JAVA / KOTLIN ---
*.class
*.bluej
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
.gradle/

# --- C++ / C / DEPLOYMENT ---
*.o
*.obj
